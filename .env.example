# PingOne environment ID that contains the DaVinci flow (Application > General tab)
BXI_COMPANY_ID=e803309e-970f-4ad2-9c9f-3569c44a2b55

# DaVinci "PingOne DaVinci Connection" application API key, used server-side only
# to exchange for an SDK token. Never expose this to the browser.
BXI_API_KEY=0131e8531196cdfe5fdc11f0c8faf7930cbf7b01c35491f288453cdc5d2876e1446527c09010e69cba2118fe20e138f608921a28d09872cf90418926c1bd9d73a48e9a306b8e3f533322f85e7e7db6f52ce98e92efba2d2dd1cf6e732d9d5d0f3f6bf9c78c28bf34821f2fbc967788fee6ef91b49421333f5e6ed2476ff0ca67

# Flow policy ID to run (Flow Policy tab). Not secret; served to the browser via /widget-config.
BXI_POLICY_ID=d0d2362f4bf29b99ba1719dbbefc2daf

# Base URL returned to the widget as apiRoot, e.g. https://auth.pingone.com
BXI_API_URL=https://auth.pingone.com

# Orchestrate API base URL used to request the sdktoken, e.g. https://orchestrate-api.pingone.com
BXI_SDK_TOKEN_URL=https://orchestrate-api.pingone.com

# PingOne region suffix used for the asset CDN: com | eu | asia | ca
PINGONE_REGION=com

# Comma separated list of allowed CORS origins. Leave blank to allow all origins.
CORS_ORIGIN=

PORT=3000
